# ==================== 决策后端配置 ====================
# 决策后端类型: llm, custom_model, utility_ai, hybrid
DECISION_BACKEND=llm

# LLM后端配置
LLM_ENDPOINT=http://localhost:8000/v1/gentext
LLM_MODEL_NAME=Qwen/Qwen2.5-1.5B-Instruct
LLM_TEMPERATURE=0.8
LLM_MAX_TOKENS=256

# 自训练模型配置(未来使用)
# CUSTOM_MODEL_PATH=models/custom_agent_model.pth
# CUSTOM_MODEL_DEVICE=cuda
# CUSTOM_MODEL_UPDATE_ENABLED=true

# Utility AI配置(未来使用)
# UTILITY_AI_ACTION_SPACE=greeting,question,statement,emotion
# UTILITY_AI_RELEVANCE_WEIGHT=0.4
# UTILITY_AI_FRIENDLINESS_WEIGHT=0.3
# UTILITY_AI_CREATIVITY_WEIGHT=0.2
# UTILITY_AI_COHERENCE_WEIGHT=0.1

# ==================== 记忆存储配置 ====================
# 存储后端类型: markdown, chromadb, milvus, pinecone
MEMORY_BACKEND=markdown

# Markdown存储配置
MEMORY_MARKDOWN_PATH=data/interactions/history.md

# 向量数据库配置(未来使用)
# VECTOR_DB_TYPE=chromadb
# VECTOR_DB_HOST=localhost
# VECTOR_DB_PORT=8000
# VECTOR_DB_COLLECTION=chrysalis_memories

# ==================== 人格配置 ====================
PERSONALITY_DIMENSIONS=10
PERSONALITY_LEARNING_RATE=0.1
PERSONALITY_STORAGE_PATH=data/personalities/current.json

# ==================== 系统配置 ====================
LOG_LEVEL=INFO
LOG_PATH=logs/chrysalis.log
API_HOST=0.0.0.0
API_PORT=8080
