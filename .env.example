# Chrysalis LLM Configuration (LangChain Version)
# Copy this file to .env and configure your settings

# LLM Provider Selection
# Supported: openai, vllm, kimi, openrouter, aihubmix, ollama, gemini, claude, minimax
LLM_PROVIDER=openai

# Base URL (optional, will auto-detect if empty)
# Examples:
#   OpenAI: https://api.openai.com/v1
#   vLLM: http://localhost:8000/v1
#   Kimi: https://api.moonshot.cn/v1
#   Ollama: http://localhost:11434
#   Claude: https://api.anthropic.com/v1
LLM_BASE_URL=

# Model Name
# Examples:
#   OpenAI: gpt-3.5-turbo, gpt-4
#   vLLM: Qwen/Qwen2.5-1.5B-Instruct
#   Kimi: moonshot-v1-8k
#   Ollama: llama2, mistral
#   Gemini: gemini-pro
#   Claude: claude-3-opus-20240229
LLM_MODEL_NAME=gpt-3.5-turbo

# API Key (required for most providers)
LLM_API_KEY=your-api-key-here

# Generation Parameters
LLM_TEMPERATURE=0.8
LLM_MAX_TOKENS=256
